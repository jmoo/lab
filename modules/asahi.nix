{
  lib',
  inputs,
  config,
  ...
}:
let
  inherit (lib'.lab) mkHostOptions mkHostPlatform;
  inherit (lib')
    filterAttrs
    mapAttrs
    mkDefault
    mkOption
    types
    ;

  # Apply the host's single home-manager configuration to its user.
  homeManager = host: {
    home-manager = {
      useGlobalPkgs = true;
      useUserPackages = true;
      users.${host.user} =
        { osConfig, ... }:
        {
          home.stateVersion = mkDefault osConfig.system.stateVersion;
          imports = [
            host.home.module
            host.asahi.home
          ];
          programs.home-manager.enable = false;
        };
    };
  };

  # Base configuration. Locale, nix, and nixpkgs config come from the shared
  # feature modules (locale.nix / nix.nix / nixpkgs.nix).
  base = {
    imports = [
      inputs.nixos-apple-silicon.nixosModules.apple-silicon-support
      inputs.home-manager-asahi.nixosModules.home-manager
    ];

    # stateVersion is stateful — pin to the host's install version (25.05),
    # independent of the pinned 25.11 nixpkgs.
    system.stateVersion = mkDefault "25.05";
  };
in
{
  options = {
    lab.hosts = mkHostOptions {
      asahi = mkHostPlatform (
        { config, ... }:
        let
          asahi = config;
        in
        {
          config = {
            module =
              { pkgs, ... }:
              {
                boot = {
                  # For ` to < and ~ to > (for those with US keyboards)
                  extraModprobeConfig = ''
                    options hid_apple iso_layout=0
                  '';

                  initrd.availableKernelModules = [
                    "usb_storage"
                    "sdhci_pci"
                  ];

                  # Extend display to notch
                  kernelParams = [
                    "apple_dcp.show_notch=1"
                  ];

                  # Use the systemd-boot EFI boot loader.
                  loader = {
                    efi.canTouchEfiVariables = false;
                    systemd-boot.enable = true;
                  };
                };

                hardware.asahi.peripheralFirmwareDirectory = mkDefault (
                  pkgs.requireFile {
                    hashMode = "recursive";
                    name = "asahi";
                    sha256 = asahi.peripheralFirmwareHash;
                    url = "file:///boot/asahi";
                  }
                );

                imports = [ base ];
              };
          };

          options = {
            home = mkOption {
              default = { };
              description = "Home-manager configuration for this platform's user";
              type = types.deferredModule;
            };

            peripheralFirmwareHash = mkOption {
              default = abort ''

                No peripheral firmware hash set.
                ---------------------------------------------------------------------------------
                1. Run `nix-hash --type sha256 --to-sri $(nix-hash --type sha256 --base32 $(nix-store --add-fixed sha256 /boot/asahi/ --recursive))` on the target machine.
                2. Set 'lab.hosts.{host}.asahi.peripheralFirmwareHash' to the sha256 hash generated by the above command.
                ---------------------------------------------------------------------------------
              '';
              type = types.str;
            };

            specialArgs = mkOption {
              default = { };
              type = types.attrsOf types.anything;
            };
          };
        }
      );
    };
  };

  config = {
    flake = {
      nixosConfigurations = mapAttrs (
        _: host:
        inputs.nixos-apple-silicon.inputs.nixpkgs.lib.nixosSystem {
          modules = [
            host.asahi.module
            (homeManager host)
          ];
          specialArgs = host.asahi.specialArgs;
          system = "aarch64-linux";
        }
      ) (filterAttrs (_: host: host.asahi.eval) config.lab.hosts);

      nixosModules = mapAttrs (_: host: {
        imports = [
          host.asahi.module
          (homeManager host)
        ];
      }) (filterAttrs (_: host: host.asahi.enable) config.lab.hosts);
    };
  };
}
